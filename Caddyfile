# Replace YOUR_DOMAIN with your actual domain (e.g. api.myapp.com)
# Caddy automatically provisions HTTPS via Let's Encrypt

auth.{$DOMAIN} {
    reverse_proxy auth-service:3009
}

upload.{$DOMAIN} {
    reverse_proxy upload-service:3001
}

extraction.{$DOMAIN} {
    reverse_proxy extraction-service:3002
}

transactions.{$DOMAIN} {
    reverse_proxy transactions-service:3003
}

analytics.{$DOMAIN} {
    reverse_proxy analytics-service:3005
}

anomaly.{$DOMAIN} {
    reverse_proxy anomaly-service:3006
}

notification.{$DOMAIN} {
    reverse_proxy notification-service:3007
}

chat.{$DOMAIN} {
    reverse_proxy chat-service:3008
}
