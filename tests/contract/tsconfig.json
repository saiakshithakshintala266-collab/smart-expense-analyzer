{
  "extends": "../../services/upload-service/tsconfig.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "typeRoots": [
      "../../node_modules/@types"
    ],
    "paths": {
      "@shared/testing":       ["../../shared/libs/testing/src/index.ts"],
      "@shared/logger":        ["../../shared/libs/logger/src/index.ts"],
      "@shared/observability": ["../../shared/libs/observability/src/index.ts"],
      "@shared/idempotency":   ["../../shared/libs/idempotency/src/index.ts"]
    }
  },
  "include": [
    "./**/*.ts",
    "../../services/upload-service/src/**/*.ts",
    "../../services/transactions-service/src/**/*.ts"
  ]
}