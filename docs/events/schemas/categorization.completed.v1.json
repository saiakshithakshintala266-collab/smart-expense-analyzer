{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/events/schemas/categorization.completed.v1.json",
  "title": "categorization.completed.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "schemaVersion",
    "occurredAt",
    "producer",
    "workspaceId",
    "actorUserId",
    "correlationId",
    "data"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "categorization.completed" },
    "eventVersion": { "const": "v1" },
    "schemaVersion": { "const": 1 },

    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "const": "categorization-service" },
    "workspaceId": { "type": "string", "minLength": 1 },
    "actorUserId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },

    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transactionId", "category"],
      "properties": {
        "transactionId": { "type": "string", "minLength": 1 },
        "category": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "name", "confidence", "source"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "source": { "type": "string", "enum": ["rule", "ml", "llm", "manual", "unknown"] }
          }
        }
      }
    }
  }
}