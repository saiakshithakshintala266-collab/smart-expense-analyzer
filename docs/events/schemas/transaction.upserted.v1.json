{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/events/schemas/transaction.upserted.v1.json",
  "title": "transaction.upserted.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "schemaVersion",
    "occurredAt",
    "producer",
    "workspaceId",
    "actorUserId",
    "correlationId",
    "data"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "transaction.upserted" },
    "eventVersion": { "const": "v1" },
    "schemaVersion": { "const": 1 },

    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "const": "transactions-service" },
    "workspaceId": { "type": "string", "minLength": 1 },
    "actorUserId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },

    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transactionId", "operation", "transaction"],
      "properties": {
        "transactionId": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "enum": ["CREATED", "UPDATED", "DELETED"] },

        "transaction": {
          "$ref": "https://example.com/schemas/transaction.schema.json"
        }
      }
    }
  }
}