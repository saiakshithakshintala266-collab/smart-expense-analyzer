{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/events/schemas/extraction.completed.v1.json",
  "title": "extraction.completed.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eventId",
    "eventType",
    "eventVersion",
    "schemaVersion",
    "occurredAt",
    "producer",
    "workspaceId",
    "actorUserId",
    "correlationId",
    "data"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "extraction.completed" },
    "eventVersion": { "const": "v1" },
    "schemaVersion": { "const": 1 },

    "occurredAt": { "type": "string", "format": "date-time" },
    "producer": { "const": "extraction-service" },
    "workspaceId": { "type": "string", "minLength": 1 },
    "actorUserId": { "type": "string", "minLength": 1 },
    "correlationId": { "type": "string", "minLength": 1 },

    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uploadFileId", "result", "extracted"],
      "properties": {
        "uploadFileId": { "type": "string", "minLength": 1 },
        "result": { "type": "string", "enum": ["SUCCESS", "PARTIAL", "FAILED"] },
        "errorMessage": { "type": "string" },

        "extracted": {
          "type": "object",
          "additionalProperties": false,
          "required": ["merchantName", "transactionDate", "amountCents", "currency", "confidence"],
          "properties": {
            "merchantName": { "type": "string" },
            "transactionDate": { "type": "string", "format": "date-time" },
            "postedDate": { "type": "string", "format": "date-time" },
            "amountCents": { "type": "integer" },
            "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },

            "rawTextS3Ref": {
              "type": "object",
              "additionalProperties": false,
              "required": ["bucket", "key"],
              "properties": {
                "bucket": { "type": "string" },
                "key": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}