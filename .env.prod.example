# Copy this file to .env.prod and fill in real values
# NEVER commit .env.prod to git

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Auth service ──────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
SESSION_TTL_DAYS=30
DDB_USERS_TABLE=Users
DDB_WORKSPACES_TABLE=Workspaces
DDB_SESSIONS_TABLE=Sessions

# ── Upload service ────────────────────────────────────────────────────────────
DDB_UPLOADFILES_TABLE=UploadFiles
UPLOADS_BUCKET=sea-uploads-prod
PRESIGN_EXPIRES_SECONDS=300

# ── Extraction service ────────────────────────────────────────────────────────
DDB_EXTRACTED_DOCS_TABLE=ExtractedDocs
SQS_EXTRACTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sea-extraction-queue
TEXTRACT_REGION=us-east-1
USE_MOCK_TEXTRACT=false

# ── Transactions service ──────────────────────────────────────────────────────
DDB_TRANSACTIONS_TABLE=Transactions
SQS_TRANSACTIONS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sea-transactions-queue

# ── Analytics service ─────────────────────────────────────────────────────────
DDB_ANALYTICS_TABLE=AnalyticsSummaries
SQS_ANALYTICS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sea-analytics-queue

# ── Anomaly service ───────────────────────────────────────────────────────────
DDB_ANOMALY_TABLE=AnomalyDetections
SQS_ANOMALY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sea-anomaly-queue

# ── Notification service ──────────────────────────────────────────────────────
DDB_NOTIFICATIONS_TABLE=Notifications
SQS_NOTIFICATIONS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/sea-notifications-queue
NOTIFY_EMAIL=

# ── Chat service ──────────────────────────────────────────────────────────────
DDB_CONVERSATIONS_TABLE=ChatConversations
ANALYTICS_SERVICE_URL=http://analytics-service:3005
ANOMALY_SERVICE_URL=http://anomaly-service:3006

# ── Shared SNS topic ──────────────────────────────────────────────────────────
EVENTS_TOPIC_ARN=arn:aws:sns:us-east-1:YOUR_ACCOUNT_ID:sea-events-prod

# ── CORS: set to your Vercel frontend URL ─────────────────────────────────────
CORS_ORIGIN=https://your-app.vercel.app
